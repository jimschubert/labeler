{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jimschubert/labeler/HEAD/model/schema/labeler.full.schema.json",
  "title": "labeler full config",
  "description": "Full labeler configuration.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enable": {
      "type": "object",
      "description": "Enable labeling for issues and/or pull requests.",
      "additionalProperties": false,
      "properties": {
        "issues": { "type": "boolean" },
        "prs": { "type": "boolean" }
      }
    },
    "comments": {
      "type": "object",
      "description": "Optional comments to add when labels are applied.",
      "additionalProperties": false,
      "properties": {
        "issues": { "type": "string" },
        "prs": { "type": "string" }
      }
    },
    "fields": {
      "type": "array",
      "description": "Optional list of fields to evaluate for labeling. If omitted/empty, the tool's defaults apply.",
      "items": {
        "type": "string",
        "enum": ["title", "body"]
      },
      "uniqueItems": true
    },
    "labels": {
      "type": "object",
      "description": "Map of label name to include/exclude/branches rules.",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/labelRule"
      }
    }
  },
  "required": ["labels"],
  "$defs": {
    "labelRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string", "minLength": 0 }
        },
        "branches": {
          "type": "array",
          "items": { "type": "string", "minLength": 0 }
        }
      },
      "required": ["include"]
    }
  }
}

